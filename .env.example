# Local development env template.
# Copy to .env.local and fill the values there. Do not commit .env.local.

API_PORT=4000
PUBLIC_APP_URL=http://localhost:5173
LOCAL_DATA_DIR=.data

# AI listing assistant
OPENAI_API_KEY="replace-with-openai-api-key"
OPENAI_LISTING_MODEL=

# Telegram owner onboarding bot
TELEGRAM_BOT_TOKEN="replace-with-telegram-bot-token"
TELEGRAM_WEBHOOK_SECRET=

# Soft launch: prices are visible, but clients pay the studio directly.
MANUAL_PAYMENT_MODE=true

# PostgreSQL used by Prisma.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/photo_studios"

# Resend for 6-digit email codes.
RESEND_API_KEY="replace-with-resend-api-key"
EMAIL_FROM="Photo Studios <hello@your-domain.com>"

# Cloudflare R2 / S3-compatible media storage.
R2_ACCOUNT_ID="replace-with-r2-account-id"
R2_ACCESS_KEY_ID="replace-with-r2-access-key-id"
R2_SECRET_ACCESS_KEY="replace-with-r2-secret-access-key"
R2_BUCKET="photo-studios"
R2_PUBLIC_BASE_URL="https://media.your-domain.com"

# Future platform payments. Leave unset while MANUAL_PAYMENT_MODE=true.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
